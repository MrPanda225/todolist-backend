// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client-js"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum ConditionType {
  STREAK
  TASKS_COMPLETED
  LEVEL_REACHED
  XP_EARNED
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  categories       Category[]
  tags             Tag[]
  tasks            Task[]
  timeBlocks       TimeBlock[]
  stats            UserStats?
  userAchievements UserAchievement[]

  @@map("users")
}

model Priority {
  id           String  @id @default(uuid())
  label        String  @unique
  level        Int     @unique
  color        String
  icon         String?
  xpMultiplier Decimal @default(1.00) @db.Decimal(3, 2)

  tasks Task[]

  @@map("priorities")
}

model Category {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String
  icon      String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@map("categories")
}

model Tag {
  id     String @id @default(uuid())
  userId String
  name   String

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskTags TaskTag[]

  @@unique([userId, name])
  @@map("tags")
}

model RecurrenceRule {
  id             String    @id @default(uuid())
  frequency      Frequency
  interval       Int       @default(1)
  daysOfWeek     String?
  endDate        DateTime?
  maxOccurrences Int?

  tasks      Task[]
  timeBlocks TimeBlock[]

  @@map("recurrence_rules")
}

model Task {
  id                String     @id @default(uuid())
  userId            String
  categoryId        String?
  priorityId        String
  recurrenceRuleId  String?
  title             String
  description       String?
  status            TaskStatus @default(TODO)
  dueDate           DateTime?
  estimatedDuration Int?
  xpReward          Int        @default(10)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  priority       Priority        @relation(fields: [priorityId], references: [id])
  recurrenceRule RecurrenceRule? @relation(fields: [recurrenceRuleId], references: [id], onDelete: SetNull)
  taskTimeBlocks TaskTimeBlock[]
  taskTags       TaskTag[]

  @@map("tasks")
}

model TimeBlock {
  id               String   @id @default(uuid())
  userId           String
  title            String
  startTime        DateTime
  endTime          DateTime
  color            String?
  isRecurring      Boolean  @default(false)
  recurrenceRuleId String?
  createdAt        DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurrenceRule RecurrenceRule? @relation(fields: [recurrenceRuleId], references: [id], onDelete: SetNull)
  taskTimeBlocks TaskTimeBlock[]

  @@map("time_blocks")
}

model TaskTimeBlock {
  taskId      String
  timeBlockId String
  assignedAt  DateTime @default(now())

  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  timeBlock TimeBlock @relation(fields: [timeBlockId], references: [id], onDelete: Cascade)

  @@id([taskId, timeBlockId])
  @@map("task_time_blocks")
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}

model UserStats {
  id               String    @id @default(uuid())
  userId           String    @unique
  totalXp          Int       @default(0)
  level            Int       @default(1)
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  tasksCompleted   Int       @default(0)
  lastActivityDate DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model Achievement {
  id             String        @id @default(uuid())
  name           String        @unique
  description    String
  icon           String
  xpBonus        Int           @default(0)
  conditionType  ConditionType
  conditionValue Int

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@id([userId, achievementId])
  @@map("user_achievements")
}
